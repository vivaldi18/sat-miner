cat > .gitignore << 'EOF'
# Environment & secrets
.env
.env.*
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
env/
.venv/

# Node.js (jika ada)
node_modules/
npm-debug.log*

# GPU / CUDA cache
*.cubin
*.ptx

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Log files
*.log
logs/

# Icon & binary (opsional, hapus jika ingin track)
icon.ico
icon_circle.png

# Build output
*.exe
*.out
*.o

# Service file lokal (sensitif)
satminer.service
EOF
